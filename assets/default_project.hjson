// inkhaven project configuration
// HJSON: comments, unquoted keys, optional commas.

{
  embeddings: {
    // fastembed model. Defaults to a multilingual model with strong Russian
    // support. Other options: MultilingualE5Base, MultilingualE5Large, BGEM3.
    model: MultilingualE5Small
    chunk_size: 800
    chunk_overlap: 0.15
  }

  llm: {
    // Provider used by the AI pane when no explicit override is passed.
    // Switch to "ollama" below for local inference.
    default: gemini
    providers: {
      gemini: {
        model: gemini-2.5-pro
        api_key_env: GEMINI_API_KEY
      }
      deepseek: {
        model: deepseek-chat
        api_key_env: DEEPSEEK_API_KEY
      }
      // Local Ollama at the default endpoint (http://localhost:11434).
      // No API key is needed — omit `api_key_env`. genai picks the Ollama
      // adapter from the model name. Pull a model first with e.g.
      // `ollama pull llama3.2`, then set `default: ollama` above.
      ollama: {
        model: llama3.2
      }
    }
  }

  editor: {
    theme: default
    tab_width: 2
    wrap: true
    // Seconds of editor inactivity before the current paragraph is
    // autosaved. Set to 0 to disable idle autosave; Ctrl+S, Ctrl+Q, and
    // paragraph-switch autosaves still fire.
    autosave_seconds: 5

    // Snowball stemmer languages used to expand the Places / Characters
    // highlight overlay. With `russian` configured a paragraph titled
    // "Москва" also lights up "Москве", "Москвою", etc.; with `english`
    // a paragraph titled "cities" matches "city".
    //
    // Supported: arabic, danish, dutch, english, finnish, french, german,
    // greek, hungarian, italian, norwegian, portuguese, romanian, russian,
    // spanish, swedish, tamil, turkish. Empty list disables stemming and
    // falls back to exact-phrase matching.
    stemming: {
      languages: [
        "english"
        "russian"
      ]
    }
  }

  hierarchy: {
    // false => Book → Chapter → Subchapter → Paragraph (default).
    // true  => Subchapter may nest arbitrarily before terminating in Paragraph.
    unbounded_subchapters: false
  }

  // Seconds between background calls to bdslib's sync (HNSW flush +
  // DuckDB checkpoint). 0 disables; saves still trigger sync explicitly.
  sync_interval_seconds: 60

  keys: {
    save:             Ctrl+s
    search:           Ctrl+/
    ai_prompt:        Ctrl+i
    next_pane:        Tab
    prev_pane:        Shift+Tab
    page_up:          PageUp
    page_down:        PageDown

    // The meta-prefix chord. Pressing this puts the TUI into meta mode;
    // the next keystroke is treated as an action selector:
    //   B/C/S/P  → add book / chapter / subchapter / paragraph
    //   D        → delete the cursor's node (subtree)
    //   ↑/↓      → reorder current node within its siblings
    //   Esc      → cancel meta mode
    // Replaces the old `Ctrl+Shift+*` chords which terminals often eat.
    meta_prefix:      Ctrl+b
  }

  prompts_file: prompts.hjson

  // Visual theme — every value is a hex RGB triple like "#RRGGBB" (or the
  // short "#RGB" form). Empty strings fall back to the shipped Catppuccin
  // Mocha defaults baked into the binary, so you only need to set the
  // fields you want to override.
  //
  // Tip: terminals that don't speak truecolor (TERM=xterm-256color is fine)
  // render the closest 256-colour neighbour automatically.
  theme: {
    // Pane chrome — base background / text and line-number / current-line
    // accents used by the editor.
    pane_bg:           "#1e1e2e"
    pane_fg:           "#cdd6f4"
    line_number_fg:    "#6c7086"
    current_line_bg:   "#313244"

    // Pane borders. Focused / unfocused get used everywhere; the editor
    // additionally switches between dirty / saved / read-only to telegraph
    // the open paragraph's state at a glance.
    border_focused:    "#cba6f7"
    border_unfocused:  "#45475a"
    border_dirty:      "#f9e2af"
    border_saved:      "#a6e3a1"
    border_readonly:   "#94e2d5"

    // Floating windows (Add / Delete / Rename / FindReplace / QuickRef /
    // FilePicker / Help / PromptPicker). All share these three colours.
    modal_bg:          "#181825"
    modal_fg:          "#cdd6f4"
    modal_border:      "#cba6f7"

    // Places / Characters overlay tints. Words that match a paragraph
    // title nested under the Places (resp. Characters) book light up in
    // these colours inside the editor.
    places_fg:         "#89dceb"
    characters_fg:     "#f9e2af"

    // In-buffer Ctrl+F search highlights (every match / the current one).
    search_match_bg:   "#f38ba8"
    search_current_bg: "#f5c2e7"

    // Tree pane chrome: colour of the ▸ marker on the currently-open
    // paragraph row.
    tree_open_marker:  "#a6e3a1"

    // Typst syntax highlight palette. Drives the colours applied to
    // tree-sitter-typst's tagged regions in the editor buffer.
    syntax_heading:     "#cba6f7"
    syntax_bold:        "#f9e2af"
    syntax_italic:      "#94e2d5"
    syntax_string:      "#a6e3a1"
    syntax_number:      "#fab387"
    syntax_comment:     "#6c7086"
    syntax_keyword:     "#cba6f7"
    syntax_function:    "#89dceb"
    syntax_operator:    "#94e2d5"
    syntax_list_marker: "#cba6f7"
    syntax_raw:         "#fab387"
    syntax_tag:         "#89b4fa"
    syntax_quote:       "#9399b2"
  }
}
