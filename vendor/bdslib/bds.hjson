{
  // ── OS resource limits ───────────────────────────────────────────────────────

  // Soft limit for open file descriptors (NOFILE) requested at startup.
  // bdsnode opens multiple DuckDB files and vecstore indexes per shard; on
  // systems where the default soft limit is 256 (macOS) or 1024 (Linux) this
  // can exhaust file descriptors after a few hours of operation.
  // The value is clamped to the process hard limit by the OS.
  // Default: 4096
  nofile_limit: 4096

  // ── Storage ──────────────────────────────────────────────────────────────────

  // Root directory where all time-partitioned shards are stored.
  // Each shard is a subdirectory named after its aligned start timestamp.
  // Required.
  dbpath: "./db"

  // Width of each time shard, in humantime notation.
  // Every document is routed to the shard whose interval contains its timestamp.
  // Common values: "1h"  "6h"  "1day"  "7days"
  // Required.
  shard_duration: "1h"

  // Maximum number of shards held open simultaneously.
  // Each open shard consumes ~12 file descriptors (obs.db + tplstorage files).
  // When the limit is reached, the least-recently-used shard is synced and closed
  // to reclaim file descriptors before the new shard is opened.
  // Default: 16
  max_open_shards: 32

  // ── DuckDB connection pool ────────────────────────────────────────────────────

  // Maximum number of concurrent DuckDB connections per shard.
  // Raise for high-concurrency ingest workloads; lower to reduce memory usage.
  // Default: 4
  pool_size: 4

  // Number of worker threads in the process-wide r2d2 maintenance thread pool.
  // A single pool is shared across all DuckDB connection pools (shards, docstore,
  // signals, tplstorage, etc.), so this is a fixed overhead regardless of how
  // many pools are open.  Raise only if you see r2d2 reaper lag under very high
  // connection churn.
  // Default: 3
  r2d2_thread_pool_size: 3

  // ── Embedding model (write-once per dbpath) ──────────────────────────────────

  // Name of the fastembed::EmbeddingModel variant to load.  Matches Rust's
  // Debug form, case-insensitive.  When unset the historical default
  // (AllMiniLML6V2) is used, so existing deployments keep working.
  //
  // Common choices:
  //   "AllMiniLML6V2"            — 384-dim, default, fast/small (~22 MB)
  //   "AllMiniLML6V2Q"           — quantized AllMiniLM, ~6 MB
  //   "BGESmallENV15"            — 384-dim, higher retrieval quality (~33 MB)
  //   "BGEBaseENV15"             — 768-dim, larger model (~110 MB)
  //   "BGELargeENV15"            — 1024-dim (~340 MB)
  //   "MultilingualE5Small"      — 384-dim, multilingual
  //   "NomicEmbedTextV15"        — 768-dim, longer context
  //   "JinaEmbeddingsV2BaseEN"   — 768-dim, 8K context window
  //
  // See `fastembed::EmbeddingModel` for the full list (~40 variants).
  //
  // WARNING — dimension lock-in.  The HNSW vector index dimension is
  // fixed at the dimension of whichever model produced the first vector
  // insert.  Switching `embedding_model` on an existing dbpath will break
  // vector search.  To switch models, rebuild the dbpath:
  //
  //     bdsnode --new --config bds.hjson
  //
  // The chosen model is reported in `v2/status` and shown on the bdsweb
  // Dashboard so you can confirm what's loaded.
  //
  // embedding_model: "AllMiniLML6V2"

  // Override the fastembed model cache directory.  When unset, fastembed
  // uses its default (~/.cache/huggingface/hub or $HF_HOME).  Useful when
  // you want model weights to live next to the data so backups are
  // self-contained.
  //
  // embedding_cache_dir: "/var/lib/bdslib/models"

  // ── Deduplication ─────────────────────────────────────────────────────────────

  // Cosine-similarity threshold for classifying an incoming document as a
  // secondary (near-duplicate) of an existing primary.
  // Range: 0.0 (no dedup) … 1.0 (exact match only).
  // Default: 0.85
  similarity_threshold: 0.85

  // ── Drain3 log-template mining ────────────────────────────────────────────────

  // Set to true to automatically mine log templates on every add() / add_batch().
  // Templates are stored in the per-shard tplstorage and can be retrieved later
  // via tpl_list(), tpl_search_text(), etc.
  // Default: false
  drain_enabled: true

  // How far back to look when loading previously discovered templates at startup.
  // Templates discovered during a previous run (within this window) are loaded
  // into the drain parser so it continues from known state rather than starting
  // from scratch.
  // Default: "24h"
  drain_load_duration: "24h"

  // ── JSON record cache ─────────────────────────────────────────────────────────

  // Maximum number of records held in the in-memory JSON cache.
  // Populated on every add()/add_batch() and on FTS/vector search result fetches.
  // Consulted before any DB round-trip. 0 disables the cache.
  // Default: 10000
  jsoncache_capacity: 10000

  // Per-entry TTL in seconds. Entries older than this are lazily removed on
  // access and eagerly swept by a background thread every 60 seconds.
  // Default: 300 (5 minutes)
  jsoncache_ttl_secs: 300

  // ── JSON file ingest ──────────────────────────────────────────────────────

  // Records accumulated before a batch is flushed to the shard store by the
  // JSON-file ingest task driven by v2/add.file (src/bin/bdsnode/server/add_file.rs).
  // Matches the syslog batch size below so both ingest paths flush at the
  // same granularity.
  // Default: 100
  file_batch_size: 500

  // Milliseconds of channel inactivity before a partial JSON-file batch is flushed.
  // Default: 5000
  file_timeout_ms: 5000

  // ── Syslog file ingest ────────────────────────────────────────────────────

  // Records accumulated before a batch is flushed to the shard store.
  // Larger values amortize per-batch ONNX embedding overhead; smaller values
  // reduce latency between file arrival and indexing.
  // Default: 500
  syslog_batch_size: 500

  // Milliseconds of channel inactivity before a partial batch is flushed.
  // Default: 5000
  syslog_timeout_ms: 5000

  // ── BUND worker pool ──────────────────────────────────────────────────────────

  // Number of threads in the process-wide BundWorkerPool.
  // Each worker creates an ephemeral BUND VM per job submitted via
  // v2/eval.queued.  Results are stored in the per-id RESULTS queue and
  // retrieved via v2/results.pull.
  // Default: 4
  n_workers: 4

  // ── Ollama LLM integration ────────────────────────────────────────────────────

  // Base URL of the Ollama HTTP server.
  // Default: "http://localhost:11434"
  ollama_url: "http://localhost:11434"

  // Model name served by Ollama to use for chat inference.
  // Run `ollama pull <model>` to download. Recommended for telemetry analysis:
  //   llama3.2       — fast, good general reasoning, 3B parameters
  //   mistral        — strong at structured reasoning and JSON
  //   qwen2.5:14b    — excellent instruction following, larger context
  ollama_model: "llama3.2"

  // ── Result queues (v2/results.*) ────────────────────────────────────────────

  // Time-to-live for per-id result queues exposed via the v2/results.* RPC
  // family.  bdsnode runs a background tokio task that, once per
  // `results_sweep_secs`, drops every queue whose creation timestamp is older
  // than `results_ttl_secs` from now.  Set `results_ttl_secs` to 0 to keep
  // queues forever (manual eviction only).
  // Default: 600 (10 minutes)
  results_ttl_secs: 600

  // How often the sweeper runs, in seconds.  Smaller values reclaim memory
  // faster; larger values reduce wakeups.  Has no effect when
  // results_ttl_secs is 0.
  // Default: 30
  results_sweep_secs: 30

  // ── Cron-driven script scheduler ─────────────────────────────────────────────

  // bdsnode spawns a background tokio task that, once per
  // `scheduler_interval_secs`, walks every BUND script stored in the script
  // registry (v2/scripts), parses the metadata `schedule` field as a crontab
  // expression, and submits any script whose next occurrence falls within the
  // current minute to the BundWorkerPool via submit_script_with_id (the
  // result-queue id is the script's storage UUID).
  //
  // Default 60 — i.e., once per minute, matching standard crontab semantics.
  // Setting this to 0 disables the scheduler entirely.  Values smaller than
  // 60 may cause "* * * * *" scripts to fire multiple times per minute.
  scheduler_interval_secs: 60

  // ── Periodic global sync ─────────────────────────────────────────────────────

  // bdsnode spawns a background tokio task that, once per
  // `sync_interval_secs`, calls `bdslib::sync_db()` — which iterates every
  // open shard and runs DuckDB CHECKPOINT, Tantivy commit, VecStore flush,
  // and tplstorage HNSW save.  Without this, sync only happens on LRU shard
  // eviction or process shutdown — meaning an unclean exit (kill -9, OOM,
  // hardware fault) loses every write since the last eviction (typically
  // hours of data on the active shard).
  //
  // Default 60 — sub-second per tick on warm WALs.  Setting this to 0
  // disables the background task entirely (sync still runs on shard
  // eviction and at shutdown).
  sync_interval_secs: 60

  // ── Ingest channel backpressure ──────────────────────────────────────────────

  // Maximum number of pending records in each ingest channel
  // (`ingest`, `ingest_file`, `ingest_file_syslog`).  When the channel is
  // full, `v2/add` / `v2/add.batch` / `v2/add.file` / `v2/add.file.syslog`
  // return JSON-RPC error -32099 ("ingest channel overloaded") so the
  // client can apply backoff + retry rather than the server OOMing on
  // an unbounded queue.
  //
  // Default: 100000.  Set to 0 for legacy unbounded behaviour.
  ingest_channel_capacity: 100000

  // ── bdsweb Dashboard ─────────────────────────────────────────────────────────

  // How often (in seconds) bdsweb polls bdsnode in the background to refresh
  // the cached Dashboard snapshot.  Page loads render from this cache; the
  // "Reload" button bypasses it and forces a live fetch.
  // Default: 30
  dashboard_refresh_secs: 30

  // System prompt injected at the start of every chat session.
  // Tailor this to your observability domain.
  ollama_system_prompt: "You are an expert site reliability engineer and telemetry analyst. You have access to real observability data from the system under analysis — structured telemetry events, log messages, and associated metadata provided in the conversation context. Your job is to help the operator understand what is happening in their system, identify anomalies or root causes, and suggest actionable remediation steps. When analysing telemetry context: look for patterns in key names, timestamps, numeric values, and co-occurring events. Distinguish signal from noise. Be concise and direct. When you reference specific events or keys from the context, quote them verbatim so the operator can trace them back. If the provided context is insufficient to answer, say so clearly and suggest what additional data would help."
}
